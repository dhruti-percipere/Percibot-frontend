{
  "eula": "",
  "license": "",
  "vendor": "Percipere",
  "id": "com.percipere.sac.percibot.dev",
  "version": "1.1.0",
  "name": "PerciBOT_Tata_Chemicals",
  "newInstancePrefix": "PerciBOT_Tata_Chemicals",
  "description": "PerciBot SAC custom widget with chat, builder configuration, prompts, connection testing, and theming support",
  "webcomponents": [
    {
      "kind": "main",
      "tag": "perci-bot",
      "url": "https://dhruti-percipere.github.io/Percibot-frontend/dist/chat-widget.js",
      "integrity": "",
      "ignoreIntegrity": true
    },
    {
      "kind": "builder",
      "tag": "perci-bot-builder",
      "url": "https://dhruti-percipere.github.io/Percibot-frontend/dist/builder.js",
      "integrity": "",
      "ignoreIntegrity": true
    }
  ],
  "properties": {
    "width": {
      "type": "integer",
      "default": 1
    },
    "height": {
      "type": "integer",
      "default": 1
    },
    "apiKey": {
      "type": "string",
      "default": ""
    },
    "model": {
      "type": "string",
      "default": "gpt-4o-mini"
    },
    "welcomeText": {
      "type": "string",
      "default": "Hello, I'm PerciBOT! How can I assist you today?"
    },
    "datasets": {
      "type": "string",
      "default": ""
    },
    "primaryColor": {
      "type": "string",
      "default": "#1f4fbf"
    },
    "primaryDark": {
      "type": "string",
      "default": "#163a8a"
    },
    "surfaceColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "surfaceAlt": {
      "type": "string",
      "default": "#f6f8ff"
    },
    "textColor": {
      "type": "string",
      "default": "#0b1221"
    },
    "answerPrompt": {
      "type": "string",
      "default": ""
    },
    "behaviourPrompt": {
      "type": "string",
      "default": ""
    },
    "schemaPrompt": {
      "type": "string",
      "default": ""
    },
    "clientId": {
      "type": "string",
      "default": ""
    },
    "schemaName": {
      "type": "string",
      "default": ""
    },
    "viewName": {
      "type": "string",
      "default": ""
    },
    "memoryMode": {
      "type": "string",
      "default": "disabled"
    }
  },
  "methods": {
    "setDatasets": {
      "description": "Attach datasets as a JSON string with { name:{schema,types,rows2D}... }.",
      "parameters": [
        {
          "name": "payload",
          "type": "string",
          "description": "Datasets JSON string."
        }
      ],
      "body": "this.datasets = payload;"
    }
  },
  "events": {}
}